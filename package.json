{
  "name": "lanpilot-audit-app",
  "private": true,
  "version": "1.5.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:i18n": "vitest run src/i18n/completeness.test.ts",
    "typecheck": "tsc --noEmit",
    "security:check": "node scripts/check-security-keywords.mjs",
    "secret:scan": "node scripts/check-open-source-secrets.mjs",
    "ui-localization:check": "node scripts/check-visible-ui-localization.mjs",
    "i18n:strict-check": "node scripts/check-i18n-strict.mjs && vitest run src/i18n/strict.test.ts",
    "i18n:visible-check": "node scripts/check-visible-i18n.mjs",
    "security:deep-check": "node scripts/check-security-deep.mjs",
    "qa:governance-fixtures": "node scripts/qa-governance-fixtures.mjs",
    "qa:installed-app": "node scripts/qa-installed-app.mjs",
    "release:remote-check": "node scripts/check-remote-release.mjs",
    "script:check": "for script in scripts/*.mjs; do node --check \"$script\" || exit 1; done",
    "workflow:check": "node scripts/check-workflow-security.mjs",
    "version:check": "node scripts/check-version-consistency.mjs",
    "engine:sync": "node scripts/sync-engine.mjs",
    "engine:sync:check": "node scripts/sync-engine.mjs --check",
    "check:core": "npm run version:check && npm run engine:sync:check && npm run workflow:check && npm run typecheck && npm run script:check && npm run ui-localization:check && npm run i18n:strict-check && npm run i18n:visible-check && cargo check --locked --manifest-path src-tauri/Cargo.toml && npm run security:check && npm run security:deep-check && npm run qa:governance-fixtures && npm audit --omit=dev --audit-level=high && npm run test:i18n && npm test && cargo test --locked --manifest-path src-tauri/Cargo.toml && cargo clippy --locked --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "check": "node scripts/run-check.mjs",
    "public:check": "node scripts/check-public-readiness.mjs",
    "app:dev": "npm run tauri -- dev",
    "app:build": "npm run tauri -- build",
    "release:local": "node scripts/release-local.mjs",
    "release:artifacts:verify": "node scripts/verify-release-artifacts.mjs",
    "release:verify": "node scripts/check-release-readiness.mjs",
    "gatekeeper:check": "node scripts/check-gatekeeper.mjs",
    "release:smoke": "node scripts/smoke-test-app.mjs",
    "release:prepare": "node scripts/prepare-release-assets.mjs",
    "checksums": "node scripts/checksums.mjs",
    "release:website": "node scripts/release-website.mjs",
    "notarize:check": "node scripts/sign-notarize.mjs --check",
    "release:public": "npm run check && npm run app:build && node scripts/sign-notarize.mjs && npm run release:website",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
